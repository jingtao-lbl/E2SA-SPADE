# Environment variables for E2SA-SPADE.
# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored.

# Anthropic API key (used by the literature-review agent's LLM screening
# and topic decomposition; only required if you run the litreview agent
# with screening enabled, which is the default for `do_themed_review`).
ANTHROPIC_API_KEY=

# NASA Earthdata Login credentials (used by the NASA ABoVE adapter for
# ORNL DAAC downloads, and by future MODIS, SMAP, and Sentinel-1 adapters
# via the earthaccess library). Register a free account at
# https://urs.earthdata.nasa.gov/.
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# Copernicus CDS API key (used by the ERA5 adapter; optional, since
# ERA5 is deprecated as the ELM forcing backstop per project conventions
# but the adapter remains available for non-ELM uses). Register at
# https://cds.climate.copernicus.eu/api-how-to.
CDS_API_KEY=

# ESS-DIVE bearer token (used by the future NGEE-Arctic adapter for
# search and metadata access on the ESS-DIVE REST API; downloads of
# open datasets work without it). Generate via ORCID login at
# https://ess-dive.lbl.gov/.
ESSDIVE_TOKEN=

# OpenAI API key (optional, used only by the report-narration / TTS
# subsystem outside the SPADE v0.1.0 surface).
OPENAI_API_KEY=
